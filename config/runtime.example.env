# Serial runtime options
MODBUS_SERIAL_PORT=COM6
MODBUS_SERIAL_BAUDRATE=115200
MODBUS_SERIAL_TIMEOUT=1
MODBUS_SLAVE_ID=1
MODBUS_PRINT_INTERVAL=0.5

# TCP runtime options (for scripts/tests)
MODBUS_TCP_HOST=127.0.0.1
MODBUS_TCP_PORT=5020
MODBUS_TCP_UNIT_ID=1

# Optional per-team overrides
MODBUS_ENV=dev
